# MongoDB connection string
# Local MongoDB (for development):
# MONGO_URL=mongodb://username:password@localhost:27017/my-gums?directConnection=true
#
# MongoDB Atlas (for production - recommended):
# MONGO_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/game?retryWrites=true&w=majority
#
# Get your Atlas connection string from: https://cloud.mongodb.com/
MONGO_URL=mongodb://username:password@localhost:27017/my-gums?directConnection=true

# Server port (default: 3000)
PORT=3000

# HTTPS mode (set to "true" to enable)
HTTPS=false

# Domain for Let's Encrypt SSL (used when HTTPS=true)
DOMAIN=example.com

# Directory for SSL certificates (default: /etc/letsencrypt/live)
CERT_DIR=/etc/letsencrypt/live

# Admin key for Arena game master commands
ADMIN_KEY=

# JWT secret for authentication (REQUIRED in production — generate a strong random string)
JWT_SECRET=

# Data directory for in-memory fallback (default: ./data)
DATA_DIR=./data

# CORS origin (default: * — set to your domain in production)
CORS_ORIGIN=*

# Prometheus metrics (default: true — set to false to disable)
ENABLE_METRICS=true

# Sentry DSN for production error monitoring (optional — leave empty to disable)
# Server errors: create a project at https://sentry.io and paste its DSN here
SENTRY_DSN=

# Sentry DSN for the client bundle (optional, can be the same DSN as above)
# Must be prefixed with VITE_ so Vite exposes it via import.meta.env at build time
VITE_SENTRY_DSN=

# Web Push (VAPID) — optional, generate locally with: npx web-push generate-vapid-keys
# Leave empty to disable push notifications entirely
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Public VAPID key exposed to the client bundle (same value as VAPID_PUBLIC_KEY above)
VITE_VAPID_PUBLIC_KEY=

# Redis (optional) — horizontal scaling prep. Leave empty to run as today (single instance,
# zero behavior change). Only needed if you deploy 2+ replicas behind a load balancer.
REDIS_URL=

# Set to "false" on every replica EXCEPT one when running 2+ instances, so only one
# instance runs the monster/poison simulation loops (the others relay only).
# Leave unset/"true" for a single-instance deployment (default, current behavior).
SIM_OWNER=true
