{
  "name": "desert-empire",
  "version": "1.0.0",
  "private": true,
  "description": "Desert Empire RTS - إمبراطورية الصحراء",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "cross-env NODE_ENV=development node server.js",
    "prod": "cross-env NODE_ENV=production node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "build": "vite build && node -e \"const fs=require('fs');fs.cpSync('config','dist/config',{recursive:true,force:true});fs.cpSync('sw.js','dist/sw.js');fs.cpSync('lands.html','dist/lands.html');fs.cpSync('assets/images','dist/assets/images',{recursive:true,force:true});fs.cpSync('img','dist/img',{recursive:true,force:true});\"",
    "vite:dev": "vite",
    "audit": "npm audit --audit-level=high",
    "prepare": "node -e \"try{require('child_process').execSync('husky',{stdio:'ignore'})}catch(e){}\""
  },
  "lint-staged": {
    "*.{js,mjs,mts,ts}": "eslint --fix",
    "*.{js,mjs,mts,ts,json,css,html}": "vitest --run --reporter=verbose --changed"
  },
  "engines": {
    "node": ">=18.17 <23"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.3",
    "nanoid": "^5.1.16",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.77",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/cli": "^4.3.2",
    "@vitest/coverage-v8": "^4.1.10",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
